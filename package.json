{
  "name": "md-view",
  "displayName": "MD View",
  "description": "在侧边栏显示 Markdown 标题大纲，支持预览模式下导航",
  "version": "0.0.8",
  "publisher": "sikilab",
  "icon": "icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/sikilab/mdview"
  },
  "galleryBanner": {
    "color": "#1e1e1e",
    "theme": "dark"
  },
  "engines": {
    "vscode": "^1.70.0"
  },
  "categories": [
    "Other",
    "Visualization"
  ],
  "keywords": [
    "markdown",
    "outline",
    "toc",
    "navigation"
  ],
  "activationEvents": [
    "onLanguage:markdown"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "views": {
      "explorer": [
        {
          "id": "mdViewOutline",
          "name": "Markdown 大纲",
          "type": "webview"
        }
      ]
    },
    "commands": [
      {
        "command": "md-view.refreshOutline",
        "title": "刷新大纲",
        "icon": "$(refresh)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "md-view.refreshOutline",
          "when": "view == mdViewOutline",
          "group": "navigation"
        }
      ]
    },
    "keybindings": [
      {
        "command": "md-view.refreshOutline",
        "key": "ctrl+shift+m",
        "mac": "cmd+shift+m",
        "when": "resourceLangId == markdown"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.70.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^9.39.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.52.0"
  }
}
